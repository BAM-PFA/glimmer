<% @page_title = t('blacklight.search.page_title.title', constraints: render_search_to_page_title(params), application_name: application_name) %>

<% content_for(:head) do -%>
  <%= render 'catalog/opensearch_response_metadata', response: @response %>
  <%= rss_feed_link_tag %>
  <%= atom_feed_link_tag %>
  <%= json_api_link_tag %>
<% end %>

<% content_for(:skip_links) do -%>
    <%= link_to t('blacklight.skip_links.first_result'), '#documents', class: 'bg-white rounded-bottom visually-hidden-focusable sr-only sr-only-focusable d-inline-flex py-2 px-3', data: { turbolinks: 'false' } %>
<% end %>

<% content_for(:container_header) do -%>
  <%= render 'search_results_header' %>
  <%= render 'constraints' %>
<% end %>

<%= render 'search_header' %>

<%- if @response.empty? %>
  <%= render "zero_results" %>
<%- elsif render_grouped_response? %>
  <%= render 'group' %>
<%- else %>
  <div class="row m-3">
    <div class="col-sm-4">
      <%= config.csv_output_fields %>
      <%= link_to "Download these search results", csv_output_fields_form_path(solr_params: params.compact_blank.except(:op,:sort,:commit,:controller,:action,:authenticity_token,:solr_params).to_json, no_vaules: nil), class: 'btn btn-primary' %>
    </div>
    <div class="col-sm-4">
      <%= link_to "Summarize these search results", summary_fields_form_path(solr_params: params.compact_blank.except(:op,:sort,:commit,:controller,:action,:authenticity_token,:solr_params).to_json, no_vaules: nil), class: 'btn btn-primary' %>
    </div>
    <div class="col-sm-4">
        <%= link_to "Map these search results", map_results_path(solr_params: params.compact_blank.except(:op,:sort,:commit,:controller,:action,:authenticity_token,:solr_params).to_json, no_vaules: nil), class: 'btn btn-primary' %>
      </div>
  </div>
  <%= render_document_index @response.documents %>
<%- end %>

<%= render 'results_pagination' %>
